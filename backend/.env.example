OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini
MAX_CONCURRENT_LLM_CALLS=3

# Supabase (required unless AUTH_DISABLED=true)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Local dev only — bypasses JWT verification
AUTH_DISABLED=false

# Comma-separated origins (use * only for local dev)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Per-user API rate limits (sliding window)
RATE_LIMIT_GENERATE_STAGES=30
RATE_LIMIT_RUN=10
RATE_LIMIT_WINDOW_SECONDS=3600

# Max JSON body size in bytes (default 1MB)
MAX_REQUEST_BYTES=1048576
